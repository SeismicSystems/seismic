{
  "extends": "../../tsconfig.base.json",
  "include": ["./src/**/*", "index.ts", "../seismic-viem/src/**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "paths": {
      "@sviem/*": ["../seismic-viem/src/*"],
      "@sbot/*": ["./src/*"]
    },
    "downlevelIteration": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "rootDir": "../.."
  }
}
